		#!/bin/sh
		LD_LIBRARY_PATH="$TEMP/"'lib-beta'"\\\${LD_LIBRARY_PATH:+:\\$LD_LIBRARY_PATH}" LD_PRELOAD="$TEMP/"'lib-beta'"/cleanup_env.so\\\${LD_PRELOAD:+:\\$LD_PRELOAD}" exec "$TEMP/orig/"'beta' "\\$@"
